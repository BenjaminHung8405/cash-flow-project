# File cấu hình môi trường (Nên ignore để tránh lộ bí mật nếu public)
# appsettings.Development.json
# appsettings.Production.json

## --- PHẦN 2: CÁC FILE RÁC HỆ THỐNG & OFFICE (Áp dụng cho tài liệu bên ngoài) ---

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# File tạm của Word/Excel (khi bạn mở tài liệu hướng dẫn)
~$*.doc*
~$*.xls*
~$*.ppt*

# Các file Log
*.log

# Visual Studio Code (Nếu bạn dùng để soạn thảo text/json bên ngoài)
.vscode/

