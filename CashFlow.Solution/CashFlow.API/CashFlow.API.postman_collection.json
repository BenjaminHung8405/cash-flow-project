              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create fund success', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const res = pm.response.json();",
                  "if (res && res.id) {",
                  "    pm.collectionVariables.set('fundId', res.id);",
                  "}"
                ]
              }
            }
          ],
          "response": []
