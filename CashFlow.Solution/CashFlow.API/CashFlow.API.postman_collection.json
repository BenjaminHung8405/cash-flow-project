{
  "info": {
    "_postman_id": "bfe4ea9c-4fd9-443e-9f88-6fe3f3584c8f",
    "name": "CashFlow API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection test API cho CashFlow.API (Auth + Funds)."
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/Auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "Auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login success', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const res = pm.response.json();",
                  "if (res && res.token) {",
                  "    pm.collectionVariables.set('token', res.token);",
                  "}",
                  "if (res && res.tenantId) {",
                  "    pm.collectionVariables.set('tenantId', res.tenantId);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"password\": \"123456\",\n  \"fullName\": \"New User\",\n  \"email\": \"newuser@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/Auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "Auth",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{token}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/Auth/refresh-token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "Auth",
                "refresh-token"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.token) {",
                  "    pm.collectionVariables.set('token', res.token);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/Auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "Auth",
                "me"
              ]
            }
          },
          "response": []
        }
      ]
